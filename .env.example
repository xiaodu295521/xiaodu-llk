NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=
MONGODB_DB=llk_codex

# JWT
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=llk-codex
JWT_AUDIENCE=llk-codex-users

# Session
SESSION_SECRET=replace-with-a-strong-session-secret

# Security
BCRYPT_ROUNDS=12
TRUST_PROXY=0
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# Admin seed
ADMIN_PHONE=13900000000
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NICKNAME=系统管理员
